# Runtime config for a self-hosted deployment — read at container start,
# never baked into the image at build time.
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=
PROGRAM_ID=
SYSTEM_ADMIN_SECRET_KEY=
SESSION_SECRET=

# If deploying behind a reverse proxy/load balancer that terminates TLS,
# ensure it always sets (never passes through a client-supplied)
# X-Forwarded-Proto header — this app trusts that header to mark the
# session cookie Secure.
